# IntelliJ Run Configuration
# Active profiles: dev
# Working directory: learning-service 저장소 루트
#
# 이 파일을 .env.dev로 복사한 뒤 학교의 개발용 DB 접속값으로 바꿉니다.
# 운영 DB 접속값은 개발 환경에 사용하지 않습니다.

SERVER_PORT=8084

# 학교 PostgreSQL의 개발용 DB 또는 schema에 접근하는 계정
DB_URL=jdbc:postgresql://<school-postgresql-host>:<port>/<development-database>
DB_USERNAME=<development-user>
DB_PASSWORD=<development-password>

# 공유 DB의 Migration은 담당 절차에서만 실행
FLYWAY_ENABLED=false

# 로컬 인스턴스를 운영 Discovery에 등록하지 않음
EUREKA_ENABLED=false
